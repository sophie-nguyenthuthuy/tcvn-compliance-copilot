# --- Environment & secrets ---
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# --- Python ---
# Python build/install artifacts — scope to the Python tree so we don't
# accidentally swallow JS dirs named `lib/`, `dist/`, `build/`.
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
apps/api/build/
apps/api/develop-eggs/
apps/api/dist/
apps/api/downloads/
apps/api/eggs/
apps/api/.eggs/
apps/api/lib/
apps/api/lib64/
apps/api/parts/
apps/api/sdist/
apps/api/var/
apps/api/wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
.python-version
.uv/
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.hypothesis/

# --- Node / Next.js ---
node_modules/
.next/
out/
.turbo/
.pnpm-store/
*.tsbuildinfo
next-env.d.ts
.vercel/

# --- OS / IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.shared.json
*.swp
*.swo
.cache/

# --- Local data ---
data/uploads/*
!data/uploads/.gitkeep_dir
data/outputs/
data/cache/
*.sqlite
*.sqlite3
*.db

# --- Standards corpus (copyrighted) ---
packages/standards-corpus/raw/
packages/standards-corpus/processed/

# --- Logs & runtime ---
*.log
logs/
.pid
docker-compose.override.yml

# --- Build artifacts ---
*.whl
*.tar.gz
report-*.pdf
report-*.json
