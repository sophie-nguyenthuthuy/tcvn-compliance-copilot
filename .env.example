# =========================================================================
# TCVN Compliance Copilot — environment template
# Copy to `.env` and fill in. Never commit `.env`.
# =========================================================================

# ---- Runtime ----
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                   # json | console

# ---- API service ----
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_CORS_ORIGINS=http://localhost:3000
API_SECRET_KEY=change-me-to-a-long-random-string
API_ACCESS_TOKEN_TTL_MINUTES=60
API_REFRESH_TOKEN_TTL_DAYS=14

# ---- Postgres + pgvector ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=tcvn
POSTGRES_PASSWORD=tcvn_dev_password
POSTGRES_DB=tcvn_copilot
DATABASE_URL=postgresql+asyncpg://tcvn:tcvn_dev_password@postgres:5432/tcvn_copilot

# ---- Redis (cache + Celery broker) ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Object storage (MinIO in dev; S3 in prod) ----
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_admin_password
S3_BUCKET_UPLOADS=tcvn-uploads
S3_BUCKET_REPORTS=tcvn-reports

# ---- Anthropic Claude ----
ANTHROPIC_API_KEY=sk-ant-replace-me
CLAUDE_REASONING_MODEL=claude-opus-4-7
CLAUDE_EXTRACTION_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_OUTPUT_TOKENS=8192
CLAUDE_PROMPT_CACHE_ENABLED=true

# ---- RAG ----
EMBEDDING_MODEL=BAAI/bge-m3                 # multilingual; good for Vietnamese
EMBEDDING_DIM=1024
RAG_TOP_K=8
RAG_RERANK_TOP_N=20
RAG_CHUNK_SIZE_TOKENS=512
RAG_CHUNK_OVERLAP_TOKENS=64

# ---- OCR ----
TESSERACT_LANG=vie+eng
OCR_DPI=300

# ---- Observability ----
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=tcvn-copilot-api
PROMETHEUS_METRICS_ENABLED=true

# ---- Retention ----
UPLOAD_RETENTION_DAYS=30
REPORT_RETENTION_DAYS=365

# ---- Web (Next.js) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string
